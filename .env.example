# Required: Google Gemini API Key
GOOGLE_API_KEY=
GOOGLE_MODEL=gemini-2.0-flash
GCP_PROJECT_ID=

# Optional tracing providers
LANGSMITH_API_KEY=
LANGSMITH_PROJECT=multi-agent-research-lab
LANGFUSE_PUBLIC_KEY=
LANGFUSE_SECRET_KEY=
LANGFUSE_HOST=https://cloud.langfuse.com

# Optional search provider
TAVILY_API_KEY=

# Runtime config
APP_ENV=local
LOG_LEVEL=INFO
MAX_ITERATIONS=6
TIMEOUT_SECONDS=60
